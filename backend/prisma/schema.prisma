generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model TleSource {
  id         Int         @id @default(autoincrement())
  name       String
  url        String      @unique
  enabled    Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  satellites Satellite[]
}

model Satellite {
  id    Int    @id // norad ID // @default(autoincrement())
  // noradId   Int      @unique // not going with separate field as this can be primary key
  name  String
  line1 String
  line2 String

  updatedAt DateTime @updatedAt

  sourceId Int?
  source   TleSource? @relation(fields: [sourceId], references: [id])
}

model GroundStation {
  id        Int      @id @default(autoincrement())
  name      String
  latitude  Float
  longitude Float
  altitude  Float    // in meters

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}