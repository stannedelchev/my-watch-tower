// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model AppConfig {
  key         String   @id // string like "core.last_satnogsdb_satellite_update"
  value       String
  description String?
  isSystem    Boolean  @default(false) // true = not user-editable
  updatedAt   DateTime @updatedAt
}

model TleSource {
  id        Int      @id @default(autoincrement())
  name      String
  url       String
  parser    String   @default("rawText") // e.g. "rawText", "satnogsdbJson", etc.
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Satellite {
  id           Int           @id // norad ID // @default(autoincrement())
  // noradId   Int      @unique // not going with separate field as this can be primary key
  name         String
  line1        String
  line2        String
  updatedAt    DateTime      @updatedAt
  isTracked    Boolean       @default(false)
  transmitters Transmitter[]
  tags         Tag[]         @relation("SatelliteTags")
  passEvents   PassEvent[]
}

// do we need to specify "SatelliteTags" instead of just "Tags"?  Probably no - no other types of Tags for now
model Tag {
  id    Int     @id @default(autoincrement())
  name  String  @unique
  color String? // hex color code, e.g. #ff0000

  satellites Satellite[] @relation("SatelliteTags")
}

model GroundStation {
  id        Int    @id @default(autoincrement())
  name      String
  latitude  Float
  longitude Float
  altitude  Float // in meters

  horizonmask String // base64 encoded 360x90 grid of bytes, each byte representing 1 degree of azimuth, each bit representing 1 degree of elevation

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  passEvents PassEvent[]
}

model Transmitter {
  id   Int    @id @default(autoincrement())
  uuid String @unique // SatNOGS UUID for upserts

  description String?
  type        String? // "Transmitter", "Transponder"
  status      String? // "active", "inactive", "deep space"

  // String to avoid precision issues - GHz frequencies can become very large numbers
  uplinkLow    String?
  uplinkHigh   String?
  downlinkLow  String?
  downlinkHigh String?

  mode   String? // "FM", "SSB", "HRPT"
  baud   Float?
  invert Boolean @default(false)

  citation String? // info URL

  updatedAt DateTime @updatedAt

  satelliteNoradId Int
  satellite        Satellite @relation(fields: [satelliteNoradId], references: [id])
}

model PassEvent {
  id              Int           @id @default(autoincrement())
  groundStationId Int
  groundStation   GroundStation @relation(fields: [groundStationId], references: [id])
  satelliteId     Int
  satellite       Satellite     @relation(fields: [satelliteId], references: [id])
  orbitNumber     Int

  aos          DateTime
  los          DateTime
  maxElevation Float
  duration     Int // in seconds

  // segments where satellite is visible (not eclipsed)
  visibleSegments String // JSON like: [{start: DateTime, end: DateTime, maxElevation: Float, duration: Int}, ...]

  // aggregations for visible segments
  totalVisibleDuration Int // in seconds
  maxVisibleElevation  Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([satelliteId, groundStationId, orbitNumber])
}
